# Configuration du Bot WhatsApp Hunter XMD

# Authentification WhatsApp
SESSION_ID=

# Serveur
PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# Mode du bot (public|private|inbox|group)
MODE=public

# Préfixe des commandes
PREFIX=.

# Informations du bot
BOT_NAME=Hunter XMD
OWNER_NAME=Kyrox Tech
OWNER_NUMBER=
DEV=

# 🔐 Sécurité - IMPORTANT: Générez des clés aléatoires!
# Utilisez: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=change-me-to-random-key-32-chars-long
ADMIN_KEY=change-me-to-random-key-16-chars-long

# Features - Statut
AUTO_STATUS_SEEN=false
AUTO_STATUS_REPLY=false
AUTO_STATUS_REACT=true
AUTO_STATUS_MSG=*Vu votre statut* 🤍

# Features - Anti-call
ANTI_CALL=true

# Features - Anti-delete
ANTI_DELETE=true
ANTI_DEL_PATH=inbox

# Features - Groupe
WELCOME=true
ADMIN_EVENTS=false
ANTI_LINK=false
ANTI_LINK_KICK=false

# Features - Messages
AUTO_REPLY=false
AUTO_REPLY_MSG=Je suis absent en ce moment! 🚀
MENTION_REPLY=false

# Features - Réactions
AUTO_REACT=false
CUSTOM_REACT=false
CUSTOM_REACT_EMOJIS=💝,💖,💗,❤️,🧡,💛,💚,💙

# Features - Lecture
READ_MESSAGE=false
READ_CMD=false
AUTO_TYPING=false
AUTO_RECORDING=false
ALWAYS_ONLINE=false

# Sécurité supplémentaire
ANTI_BAD=false
ANTI_VV=true

# Images et URLs
MENU_IMAGE_URL=https://via.placeholder.com/400
ALIVE_IMG=https://via.placeholder.com/400
ALIVE_MSG=Je suis en ligne et prêt à servir! 🎯

# Stickers
STICKER_NAME=Hunter XMD Stickers
AUTO_STICKER=false

# Bio Auto
AUTO_BIO=false
TIME_ZONE=Europe/Paris

# Debug
DEBUG=false
